# Auth
AUTHENTIK_BASE_URL=https://auth.alien.club
AUTHENTIK_APP_SLUG=datastreaming
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Platform Backend
PLATFORM_API_URL=http://localhost:3333

# Data Cluster
CLUSTER_ID=77
DATACLUSTER_MCP_URL=

# Database (Postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5435/alien_agents

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Org onboarding (optional — omit both to disable auto-provisioning)
# ADMIN_TOKEN: an API secret token issued to an org-admin user on the platform
# ORG_ID: the numeric ID of the enterprise organization users should be added to
ADMIN_TOKEN=
ORG_ID=
