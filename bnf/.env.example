# Fichier d'exemple — copiez ce fichier en `.env.local` et renseignez les vraies valeurs.
# `.env.local` est gitignorée et ne doit JAMAIS être committée.
# Les valeurs ci-dessous sont des placeholders : elles ne fonctionnent pas telles quelles.

# Base de données (Postgres 16 lancé via docker-compose.yml sur le port 5437)
# Note : 5434-5436 sont réservés aux autres services de la plateforme parente.
DATABASE_URL=postgresql://bnf_user:bnf_dev_password@localhost:5437/bnf_dev

# Authentification — better-auth
# Générer avec : openssl rand -hex 32
BETTER_AUTH_SECRET=<openssl rand -hex 32>
BETTER_AUTH_URL=http://localhost:3000

# SSO Alien Auth (Authentik) — OPTIONNEL.
# Renseignez ces 4 variables pour activer la connexion « Se connecter avec Alien ».
# Absentes → l'app démarre en mode e-mail/mot de passe uniquement (le bouton SSO
# ne s'affiche pas). Les identifiants sont PARTAGÉS avec la démo alien-agents
# (même application Authentik `datastreaming`) — demandez-les à l'équipe Alien,
# NE JAMAIS committer les vraies valeurs (.env.local est gitignoré).
# Important (dev local) : l'URL de callback
#   http://localhost:3001/api/auth/oauth2/callback/authentik
# doit être déclarée dans l'application Authentik `datastreaming`.
AUTHENTIK_BASE_URL=https://auth.alien.club
AUTHENTIK_APP_SLUG=datastreaming
AUTHENTIK_CLIENT_ID=<obtenir auprès d'Alien — NE PAS COMMITTER>
AUTHENTIK_CLIENT_SECRET=<obtenir auprès d'Alien — NE PAS COMMITTER>

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Fournisseur de l'agent — quelle passerelle pilote le mode `claude` (@alien/chat-sdk v0.7+).
#   anthropic   → (défaut) appelle Anthropic directement avec ANTHROPIC_API_KEY.
#   openrouter  → route les MÊMES tours + outils + MCP via la passerelle OpenRouter
#                 (une seule clé pour tous les fournisseurs, accès aux modèles
#                 non-Anthropic : GPT, Gemini, Llama…). Retour arrière = remettre `anthropic`.
# Choix fixé au démarrage (le runtime durable ne tient qu'un seul runner), pas par requête.
AGENT_PROVIDER=anthropic

# Clé API OpenRouter (sk-or-…). REQUISE lorsque AGENT_PROVIDER=openrouter — le serveur
# refuse de démarrer sinon (pas de défaut silencieux pour un secret). Ignorée sous
# le fournisseur `anthropic` par défaut. Obtenir sur https://openrouter.ai/keys.
OPENROUTER_API_KEY=sk-or-...

# MCP (BnF, slice 2+)
# BNF_MCP_URL default points at the production-deployed MCP — usable in dev too.
# No local docker-compose container for the MCP; docker-compose.yml runs Postgres only.
BNF_MCP_URL=https://bnf.mcp.alien.club/mcp
# Long-lived service token; ask the Alien platform team. NEVER commit. .env.local is gitignored.
BNF_MCP_TOKEN=<obtenir auprès d'Alien — NE PAS COMMITTER>

# Application base URL (used to build cluster callback URLs)
APP_URL=http://localhost:3000

# Cluster integration (slice 4+)
# CLUSTER_MODE governs BOTH the ingest path and the research RAG path:
#   fake → in-process fake ingestion + FakeRagRunner (fixtures, no network)
#   real → real cluster worker (ingest) + RealRagRunner (data-cluster MCP)
# Switch to "real" once the cluster API and the data-cluster MCP are available.
CLUSTER_MODE=fake

# Data-cluster MCP — REAL RAG only (CLUSTER_MODE=real). The research agent's
# rag_query tool queries datacluster_vector_search_chunks over the project's
# dataset (slug `bnf-<projectId>`). Required when CLUSTER_MODE=real; the app
# boots without them and throws on the first real RAG call if absent.
DATACLUSTER_MCP_URL=https://mcp-test-bnf-corpus-1781899491112.mcp.alpha.alien.club/mcp
# Opaque service bearer token (oat_...); ask the Alien platform team. NEVER commit.
CLUSTER_BEARER_TOKEN=<obtenir auprès d'Alien — NE PAS COMMITTER>

# HMAC secret for cluster progress callbacks.  Generate with:
#   openssl rand -hex 32
# Required only when CLUSTER_MODE=real; fake mode generates per-job secrets.
JOB_CALLBACK_SECRET=<openssl rand -hex 32>

# Duration of each fake ingestion stage in milliseconds (default 5000).
# Lower this in dev to speed up integration testing.
FAKE_CLUSTER_STAGE_MS=5000

# Langfuse observability — OPTIONAL.
# Set all three and @alien/chat-sdk (v0.5+) traces every agent turn to Langfuse
# automatically: one trace per turn, a generation per Claude call, a span per
# tool, grouped by session and attributed to the user. Leave unset → tracing off.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Relais navigateur Gallica — OPTIONNEL, RUSTINE DÉMO (laisser vide en prod).
# Cloudflare (bot-fight-mode) sur gallica.bnf.fr renvoie 403 sur l'empreinte
# TLS/HTTP2 du serveur — un vrai navigateur depuis la même IP passe, et le
# cookie cf_clearance est lié à l'IP : injecter un cookie capturé NE marche PAS
# côté serveur. Renseigner cette URL route les appels gallica.bnf.fr du
# résolveur de métadonnées (lib/bnf/direct.ts) via le sidecar curl_cffi (Firefox)
# — le MÊME relais que le worker d'ingestion (worker/gallica-relay.py).
# Absente → le résolveur parle à Gallica en direct (prod, une fois l'allowlist
# IP partenaire BnF en place). Démarrer le relais : `python worker/gallica-relay.py`.
GALLICA_RELAY_URL=http://localhost:8791

# Broker BnF — OPTIONNEL. Point d'entrée unique pour TOUT le trafic BnF : il
# détient le token OAuth + les quotas partagés (300/min global, 12/min/IP pour
# les manifests, politesse pour oai/catalogue/data) + le backoff 429. Voir
# broker/. Quand défini, le résolveur de métadonnées (lib/bnf/direct.ts) route
# TOUS ses appels BnF via le broker (remplace le relais curl_cffi et l'accès
# direct). Absent → repli sur le transport direct/relais. La KEY/SECRET BnF
# vivent dans le broker, PAS ici. Démarrer : cd broker && npm start.
BNF_BROKER_URL=http://localhost:8792
