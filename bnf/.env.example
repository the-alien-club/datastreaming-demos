# Fichier d'exemple — copiez ce fichier en `.env.local` et renseignez les vraies valeurs.
# `.env.local` est gitignorée et ne doit JAMAIS être committée.
# Les valeurs ci-dessous sont des placeholders : elles ne fonctionnent pas telles quelles.

# Base de données (Postgres 16 lancé via docker-compose.yml sur le port 5437)
# Note : 5434-5436 sont réservés aux autres services de la plateforme parente.
DATABASE_URL=postgresql://bnf_user:bnf_dev_password@localhost:5437/bnf_dev

# Authentification — better-auth
# Générer avec : openssl rand -hex 32
BETTER_AUTH_SECRET=<openssl rand -hex 32>
BETTER_AUTH_URL=http://localhost:3000

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# MCP (BnF, slice 2+)
# BNF_MCP_URL default points at the production-deployed MCP — usable in dev too.
# No local docker-compose container for the MCP; docker-compose.yml runs Postgres only.
BNF_MCP_URL=https://bnf.mcp.alien.club/mcp
# Long-lived service token; ask the Alien platform team. NEVER commit. .env.local is gitignored.
BNF_MCP_TOKEN=<obtenir auprès d'Alien — NE PAS COMMITTER>

# Application base URL (used to build cluster callback URLs)
APP_URL=http://localhost:3000

# Cluster integration (slice 4+)
# CLUSTER_MODE=fake runs an in-process fake cluster that simulates the four
# ingestion stages with realistic timing.  Switch to "real" once the cluster
# API is available.
CLUSTER_MODE=fake

# HMAC secret for cluster progress callbacks.  Generate with:
#   openssl rand -hex 32
# Required only when CLUSTER_MODE=real; fake mode generates per-job secrets.
JOB_CALLBACK_SECRET=<openssl rand -hex 32>

# Duration of each fake ingestion stage in milliseconds (default 5000).
# Lower this in dev to speed up integration testing.
FAKE_CLUSTER_STAGE_MS=5000

# Langfuse observability — OPTIONAL.
# Set all three and @alien/chat-sdk (v0.5+) traces every agent turn to Langfuse
# automatically: one trace per turn, a generation per Claude call, a span per
# tool, grouped by session and attributed to the user. Leave unset → tracing off.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
