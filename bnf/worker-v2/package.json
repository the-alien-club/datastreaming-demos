{
  "name": "bnf-ingest-v2",
  "private": true,
  "type": "module",
  "description": "BnF ingest worker V2 — staged dataflow pipeline of durable buckets.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:one": "node --import tsx --test",
    "start": "node --import tsx src/main.ts",
    "seed": "node --import tsx src/seed.ts",
    "status": "node --import tsx src/status.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.677.0",
    "@google/genai": "^2.9.0",
    "@mistralai/mistralai": "^2.3.0",
    "fast-xml-parser": "^5.9.3",
    "pg": "^8.13.1",
    "pg-boss": "^10.1.5",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
