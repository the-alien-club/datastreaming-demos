# --- Postgres (local docker-compose at bnf/docker-compose.yml) ---
PG_HOST=localhost
PG_PORT=5437
PG_DATABASE=bnf_dev
PG_USER=bnf_user
PG_PASSWORD=bnf_dev_password
# Combined URL used by pg-boss and pg
DATABASE_URL=postgresql://bnf_user:bnf_dev_password@localhost:5437/bnf_dev

# --- Blob storage (Scaleway Object Storage) ---
# BlobStore selection: "local" (./data/) for first-run debug, "s3" for real
BLOB_STORE=s3
SCW_S3_BUCKET=bnf-corpus-demo
SCW_S3_ACCESS_KEY=
SCW_S3_SECRET_KEY=
SCW_S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
SCW_S3_REGION=fr-par
# Optional local fallback (used when BLOB_STORE=local)
LOCAL_BLOB_ROOT=./data

# --- Scaleway Generative API (Track 1 PRIMARY image description: Holo2) ---
SCW_API_KEY=
SCW_GENAI_BASE_URL=https://api.scaleway.ai/77c152cc-4d27-4d9b-a449-143df07bcaad/v1
HOLO_MODEL=holo2-30b-a3b

# --- Google AI (Track 1 vision; primary or fallback per VISION_PRIMARY) ---
GOOGLE_AI_API_KEY=
GEMINI_VISION_MODEL=gemma-4-31b-it
# Vision provider order: "holo" (Scaleway primary) or "gemini" (Gemini primary,
# use while Holo is down).
VISION_PRIMARY=holo

# --- RunPod bge-m3 embedder (used by Track 3) ---
RUNPOD_API_KEY=
RUNPOD_EMBEDDING_ENDPOINT_ID=pngrbp0y1aj28i
RUNPOD_EMBEDDING_MODEL=BAAI/bge-m3

# --- Data cluster (used by Track 3) ---
# Proxy mode: BACKEND_API_URL + /clusters/<id>/proxy is the data API base
BACKEND_API_URL=https://api.alpha.alien.club
CLUSTER_ID=
CLUSTER_BEARER_TOKEN=

# --- Worker HTTP API (used by the app to submit jobs) ---
WORKER_HTTP_PORT=7777
# Host the worker posts progress callbacks to. In Docker on native Linux:
# http://host.docker.internal:3001 (see docker-compose extra_hosts).
APP_BASE_URL=http://host.docker.internal:3001

# --- BnF broker (PARTNER API — preferred path) ---
# When set, ALL BnF traffic goes through the broker (broker/ service): it owns
# the OAuth token + the shared 300/min global / 12-per-IP manifest / politeness
# rate caps. The worker then uses the PARTNER API: ungated OAI-PMH metadata,
# IIIF v3 per-page ALTO for OCR, IIIF v3 images for vision. The BnF KEY/SECRET
# live in the broker, NOT here. Unset → the worker falls back to the legacy
# gallica.bnf.fr path below (OAIRecord/Pagination/viewer scrape + relay).
BNF_BROKER_URL=http://host.docker.internal:8792
# Partner IIIF base (broker mode only). MUST be the token'd host
# openapiproext.bnf.fr — NOT openapi.bnf.fr (public anonymous-IP mirror).
# BNF_API_BASE_URL=https://openapiproext.bnf.fr
# Per-doc ALTO fetch concurrency on the partner OCR path. In-flight ALTO =
# WORKER_CONCURRENCY × BNF_ALTO_CONCURRENCY; keep the product small (≈4) so the
# fleet doesn't overshoot the broker's shared 300/min cap → mass 429-shed.
BNF_ALTO_CONCURRENCY=2

# --- Gallica browser-handshake relay (LEGACY STOPGAP — superseded by the broker) ---
# Only used when BNF_BROKER_URL is unset. Cloudflare bot-fight-mode on
# gallica.bnf.fr blocks this worker's TLS/HTTP2 fingerprint; this curl_cffi
# (Firefox) relay routes legacy Gallica fetches through a browser handshake.
# Blank = direct. NOT a path to scale — that needs the BnF partner quota.
GALLICA_RELAY_URL=

# --- Gallica rate limiting ---
# STRICT — ALTO endpoint only (fallback OCR path). 0.083 rps = 5 req/min.
GALLICA_RPS=0.083
GALLICA_BURST=5
# GENERAL — OAIRecord / Pagination / manifest / IIIF image fetch (not under the
# ALTO quota). Gallica enforces a per-IP ceiling: 8 rps sustained got our IP
# hard-blocked. 3 rps / burst 4 stays under it.
GALLICA_GENERAL_RPS=3
GALLICA_GENERAL_BURST=4
# Viewer-OCR (primary OCR source) parallelism.
VIEWER_OCR_CONCURRENCY=10
VIEWER_OCR_DELAY_MS=40

# --- Ingest reliability (slow-but-completes) ---
# A long OCR book at 5 req/min legitimately takes tens of minutes; these keep
# pg-boss patient instead of force-expiring + retry-looping the job.
# NOTE: keep these values comment-free — Node's loadEnvFile keeps everything
# after `=`, so an inline `# comment` becomes part of the value and breaks
# integer parsing.
# 4h per-doc wall-clock ceiling:
INGEST_JOB_EXPIRE_SECONDS=14400
# retries per doc (runner allows limit+1 total attempts):
INGEST_RETRY_LIMIT=5
# base backoff seconds, doubles each retry (60,120,240,480,960 ≈ 32 min span).
# Long enough to outlast a Gallica throttle window if tripped; parked docs show
# as "N en reprise" in the UI (not a frozen bar), so a long park is safe UX.
INGEST_RETRY_DELAY_SECONDS=60
# hard ceiling on OCR pages per document:
MAX_OCR_PAGES=300
# hard ceiling on Holo-described canvases per doc:
MAX_IMAGE_CANVASES=40
# parallel Holo calls — also gates concurrent IIIF image fetches to Gallica:
IMAGE_CONCURRENCY=2
# parallel doc-jobs (all share the broker's one global token bucket). Capped low
# so WORKER_CONCURRENCY × BNF_ALTO_CONCURRENCY stays ≈4 (under the 300/min cap):
WORKER_CONCURRENCY=2
