# BnF broker — copy to .env and fill the real credentials. NEVER commit .env.
# The BnF KEY/SECRET live ONLY here; the app and worker hold no BnF credentials.

# OAuth2 client_credentials (from BnF onboarding). REQUIRED — no default.
BNF_CLIENT_KEY=<obtenir auprès de la BnF — NE PAS COMMITTER>
BNF_CLIENT_SECRET=<obtenir auprès de la BnF — NE PAS COMMITTER>
BNF_OAUTH_TOKEN_URL=https://apimauthproext.bnf.fr/oauth2/token

# Upstream partner API base (authenticated, global cap).
BNF_API_BASE_URL=https://openapi.bnf.fr

# Rate caps (requests/min) — these WILL rise; bump without a redeploy.
# Defaults from LIVE MEASUREMENT (2026-06-24, sandbox key), not the brief:
#   - global: brief says 300, but measured ~150–185/min enforced → default 150 (safe).
#   - manifest: verified EXACTLY 12/min/IP.
# Both are fixed clock-minute windows (reset on :00). Raise once BnF confirms prod tier.
BNF_GLOBAL_RPM=150          # partner API, all endpoints combined (per credential)
BNF_MANIFEST_RPM=12         # IIIF Presentation manifest, per IP
BNF_EXTERNAL_RPM=120        # ungated hosts (oai/catalogue/data.bnf.fr) — politeness only

# Server
PORT=8792

# Tuning (optional)
# BNF_GLOBAL_BURST=30  BNF_MANIFEST_BURST=4  BNF_EXTERNAL_BURST=20
# BNF_TOKEN_SKEW_SEC=60  BNF_UPSTREAM_TIMEOUT_MS=30000  BNF_TOKEN_TIMEOUT_MS=10000
