# Anthropic API Key (Required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAIRE MCP server URL (optional — discovered from plugin marketplace if unset)
# OPENAIRE_MCP_URL=https://your-mcp-server.example.com/mcp

# Plugin marketplace config
# MARKETPLACE_REPO=your-org/claude-marketplace
# MARKETPLACE_BRANCH=local

# Authentik OAuth (Required for authentication)
NEXT_PUBLIC_AUTHENTIK_BASE_URL=https://your-authentik-instance.example.com
AUTHENTIK_CLIENT_ID=your_client_id
AUTHENTIK_CLIENT_SECRET=your_client_secret
AUTHENTIK_APP_SLUG=datastreaming

# Better Auth (Required)
BETTER_AUTH_SECRET=generate-a-strong-random-secret
BETTER_AUTH_URL=http://localhost:3002

# Docker image (for docker-compose)
# DOCKER_IMAGE=your-registry/demo-openaire:latest
