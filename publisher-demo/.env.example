PLATFORM_API_URL=https://api.staging.alien.club
MCP_ALIEN_URL=https://mcp.alien.club
ADMIN_OAT=oat_xxxxxxxxxxxxxxxxxxxx
DEMO_CONFIG_SLUG=cfg_publisher_demo
DEMO_WORKFLOW_ID=wf_xxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Numeric organization id — forwarded as `x-organization-id` on every
# platform request (admin OAT, Mode A Responses API, Mode B mcp-alien) so
# the demo is locked to a single tenant regardless of the OAT user's other
# org memberships.
ORG_ID=123

# Optional whitelists of platform IDs the demo is allowed to surface. Empty
# / unset means "no filter" — every cluster + connector the configured org
# can see appears in the Datasources and External APIs panels. With a
# whitelist, the picker draft and the saved-state merge both respect it:
# entries hidden by the whitelist are kept untouched on save, never shown.
CLUSTER_WHITELIST=
CONNECTOR_WHITELIST=
